{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Windows Computer Use",
	"version": "0.7.0",
	"identifier": "com.sandraschi.windows-computer-use-mcp",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://127.0.0.1:10788",
		"beforeBuildCommand": "pwsh -NoProfile -File ./scripts/build-desktop.ps1",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Windows Computer Use",
				"width": 1280,
				"height": 860,
				"resizable": true
			}
		],
		"security": {
			"csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:10789 ipc: http://ipc.localhost; img-src 'self' data: http://127.0.0.1:10789; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["msi", "nsis"],
		"icon": ["icons/icon.png", "icons/icon.ico"],
		"resources": [
			"resources/windows-computer-use-backend.exe",
			"../scripts/install-mcp-clients.ps1",
			"../scripts/install-tesseract.ps1"
		],
		"windows": {
			"webviewInstallMode": {
				"type": "skip"
			},
			"nsis": {
				"installerHooks": "./windows/hooks.nsh",
				"installMode": "currentUser",
}
		}
	},
	"plugins": {}
}

