{
  "name": "windows-computer-use-mcp",
  "version": "0.4.2",
  "type": "server",
  "runtime": "python",
  "entry_point": "src/windows_computer_use_mcp/server.py",
  "dependencies": [
    "fastmcp>=3.2.0,<4.0.0",
    "pywinauto>=0.6.8"
  ],
  "build": {
    "include": [
      "src/**/*",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "tests/",
      ".git/",
      "__pycache__/",
      "*.pyc",
      ".venv/",
      "dist/",
      "build/",
      "target/",
      "docs/",
      "scripts/"
    ]
  },
  "scripts": {
    "build": "mcpb build",
    "pack": "mcpb pack . dist/windows-computer-use-mcp.mcpb",
    "test": "python -m pytest"
  }
}